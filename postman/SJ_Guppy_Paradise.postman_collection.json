{
  "info": {
    "_postman_id": "92ed5274-16a1-43bb-b73b-9da84c75a33d",
    "name": "SJ Guppy Paradise API",
    "description": "Complete public and private API collection. Run Admin Login before protected admin requests. Postman stores the HTTP-only admin cookie automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "fishId", "value": "" },
    { "key": "fishSlug", "value": "blue-mosaic-guppy" },
    { "key": "orderId", "value": "" },
    { "key": "chatId", "value": "" },
    { "key": "sessionId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - System",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }, "description": "Confirms that the API server is running." },
          "response": []
        }
      ]
    },
    {
      "name": "02 - Admin Authentication",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Logs in the administrator and sets the sj_admin_token HTTP-only cookie. Postman normally saves this cookie automatically."
          },
          "response": []
        },
        {
          "name": "Current Admin",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }, "description": "Protected: returns the logged-in administrator." },
          "response": []
        },
        {
          "name": "Admin Logout",
          "request": { "method": "POST", "header": [], "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }, "description": "Clears the admin authentication cookie." },
          "response": []
        }
      ]
    },
    {
      "name": "03 - Fish Catalogue",
      "item": [
        {
          "name": "Get All Fish",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/fish", "host": ["{{baseUrl}}"], "path": ["fish"] }, "description": "Public: returns every fish listing." },
          "response": []
        },
        {
          "name": "Filter Available Fish",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/fish?status=available&featured=true&search=mosaic", "host": ["{{baseUrl}}"], "path": ["fish"], "query": [{ "key": "status", "value": "available" }, { "key": "featured", "value": "true" }, { "key": "search", "value": "mosaic" }] }, "description": "Public: optional status, featured, and search filters." },
          "response": []
        },
        {
          "name": "Get Fish by ID or Slug",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/fish/{{fishSlug}}", "host": ["{{baseUrl}}"], "path": ["fish", "{{fishSlug}}"] }, "description": "Public: use either the fish MongoDB ID or its slug." },
          "response": []
        },
        {
          "name": "Create Fish",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const data = pm.response.json();", "if (data.fish && data.fish._id) {", "  pm.environment.set('fishId', data.fish._id);", "  pm.environment.set('fishSlug', data.fish.slug);", "}"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Blue Mosaic Guppy\",\n  \"strain\": \"Blue Mosaic\",\n  \"description\": \"Healthy breeder-selected pair with broad patterned tails.\",\n  \"price\": 650,\n  \"quantity\": 5,\n  \"sex\": \"pair\",\n  \"age\": \"4 months\",\n  \"status\": \"available\",\n  \"featured\": true,\n  \"media\": []\n}" },
            "url": { "raw": "{{baseUrl}}/fish", "host": ["{{baseUrl}}"], "path": ["fish"] },
            "description": "Protected: creates a fish and saves its ID and slug into the selected Postman environment."
          },
          "response": []
        },
        {
          "name": "Update Fish",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Blue Mosaic Guppy\",\n  \"strain\": \"Blue Mosaic\",\n  \"description\": \"Updated description for this healthy breeder-selected pair.\",\n  \"price\": 700,\n  \"quantity\": 4,\n  \"sex\": \"pair\",\n  \"age\": \"4 months\",\n  \"status\": \"available\",\n  \"featured\": true\n}" },
            "url": { "raw": "{{baseUrl}}/fish/{{fishId}}", "host": ["{{baseUrl}}"], "path": ["fish", "{{fishId}}"] },
            "description": "Protected: updates the selected fish."
          },
          "response": []
        },
        {
          "name": "Delete Fish",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/fish/{{fishId}}", "host": ["{{baseUrl}}"], "path": ["fish", "{{fishId}}"] }, "description": "Protected: permanently deletes the selected fish." },
          "response": []
        }
      ]
    },
    {
      "name": "04 - Customer Enquiries",
      "item": [
        {
          "name": "Create Customer Enquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customer\": {\n    \"name\": \"Arun Kumar\",\n    \"phone\": \"+91 9876543210\",\n    \"email\": \"arun@example.com\",\n    \"address\": \"Chennai, Tamil Nadu\"\n  },\n  \"items\": [\n    {\n      \"fish\": \"{{fishId}}\",\n      \"quantity\": 1\n    }\n  ],\n  \"notes\": \"Please confirm whether delivery is available this weekend.\"\n}" },
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "description": "Public: submits an enquiry. It does not take payment or automatically reserve stock."
          },
          "response": []
        },
        {
          "name": "Get All Enquiries",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const data = pm.response.json();", "if (data.orders && data.orders.length) pm.environment.set('orderId', data.orders[0]._id);"] } }],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }, "description": "Protected: lists all enquiries and stores the newest order ID." },
          "response": []
        },
        {
          "name": "Update Enquiry Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"confirmed\"\n}" },
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["orders", "{{orderId}}", "status"] },
            "description": "Protected. Allowed values: new, confirmed, preparing, shipped, completed, cancelled."
          },
          "response": []
        }
      ]
    },
    {
      "name": "05 - Customer and Admin Chat",
      "item": [
        {
          "name": "Create Customer Chat Session",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const data = pm.response.json();", "if (data.chat) {", "  pm.environment.set('sessionId', data.chat.sessionId);", "  pm.environment.set('chatId', data.chat._id);", "}"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customerName\": \"Arun Kumar\"\n}" },
            "url": { "raw": "{{baseUrl}}/chat/session", "host": ["{{baseUrl}}"], "path": ["chat", "session"] },
            "description": "Public: creates a customer session and stores sessionId and chatId automatically."
          },
          "response": []
        },
        {
          "name": "Get Customer Chat Session",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/chat/session/{{sessionId}}", "host": ["{{baseUrl}}"], "path": ["chat", "session", "{{sessionId}}"] }, "description": "Public: retrieves messages and the current session status." },
          "response": []
        },
        {
          "name": "Send Customer Message to AI",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Which guppies are available and what are their prices?\"\n}" },
            "url": { "raw": "{{baseUrl}}/chat/session/{{sessionId}}/message", "host": ["{{baseUrl}}"], "path": ["chat", "session", "{{sessionId}}", "message"] },
            "description": "Public: adds the customer message. AI replies only while status is ai."
          },
          "response": []
        },
        {
          "name": "Request Human Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customerName\": \"Arun Kumar\",\n  \"customerPhone\": \"+91 9876543210\"\n}" },
            "url": { "raw": "{{baseUrl}}/chat/session/{{sessionId}}/request-admin", "host": ["{{baseUrl}}"], "path": ["chat", "session", "{{sessionId}}", "request-admin"] },
            "description": "Public: changes the session to pending. Admin must accept it before live conversation."
          },
          "response": []
        },
        {
          "name": "Get All Chats for Admin",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const data = pm.response.json();", "if (data.chats && data.chats.length) pm.environment.set('chatId', data.chats[0]._id);"] } }],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/chat/admin", "host": ["{{baseUrl}}"], "path": ["chat", "admin"] }, "description": "Protected: returns recent customer conversations." },
          "response": []
        },
        {
          "name": "Accept Chat Request",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"accepted\"\n}" },
            "url": { "raw": "{{baseUrl}}/chat/admin/{{chatId}}/status", "host": ["{{baseUrl}}"], "path": ["chat", "admin", "{{chatId}}", "status"] },
            "description": "Protected. Allowed values: ai, pending, accepted, active, closed."
          },
          "response": []
        },
        {
          "name": "Send Admin Reply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Hello Arun, I can help you with the available guppies and delivery.\"\n}" },
            "url": { "raw": "{{baseUrl}}/chat/admin/{{chatId}}/message", "host": ["{{baseUrl}}"], "path": ["chat", "admin", "{{chatId}}", "message"] },
            "description": "Protected: sends an admin message and changes status to active."
          },
          "response": []
        },
        {
          "name": "Close Chat",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"closed\"\n}" },
            "url": { "raw": "{{baseUrl}}/chat/admin/{{chatId}}/status", "host": ["{{baseUrl}}"], "path": ["chat", "admin", "{{chatId}}", "status"] },
            "description": "Protected: closes the selected customer conversation."
          },
          "response": []
        }
      ]
    },
    {
      "name": "06 - Site Settings",
      "item": [
        {
          "name": "Get Public Site Settings",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/settings", "host": ["{{baseUrl}}"], "path": ["settings"] }, "description": "Public: returns homepage and business contact settings." },
          "response": []
        },
        {
          "name": "Update Site Settings",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"businessName\": \"SJ Guppy Paradise\",\n  \"heroTitle\": \"Colour that comes alive\",\n  \"heroSubtitle\": \"Healthy, home-bred premium guppies raised with care.\",\n  \"phone\": \"+91 9876543210\",\n  \"whatsapp\": \"919876543210\",\n  \"email\": \"contact@sjguppyparadise.com\",\n  \"location\": \"Chennai, Tamil Nadu\",\n  \"deliveryNote\": \"Live-fish delivery is confirmed before payment.\",\n  \"careTips\": [\n    { \"title\": \"Stable water\", \"text\": \"Use a cycled aquarium around 24–28°C.\" },\n    { \"title\": \"Small feeds\", \"text\": \"Feed small portions once or twice daily.\" }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/settings", "host": ["{{baseUrl}}"], "path": ["settings"] },
            "description": "Protected: updates public website content."
          },
          "response": []
        }
      ]
    },
    {
      "name": "07 - Media Upload",
      "item": [
        {
          "name": "Upload Fish Image or Video",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": [] }] },
            "url": { "raw": "{{baseUrl}}/media", "host": ["{{baseUrl}}"], "path": ["media"] },
            "description": "Protected: choose a local image or video in Body > form-data. Do not manually add Content-Type; Postman creates the multipart boundary. Copy the returned media object into a fish media array."
          },
          "response": []
        }
      ]
    }
  ]
}

